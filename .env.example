# API Keys for the AI Tourism Assistant Agent

# Gemini API Key (Required for primary AI)
TRAVEL_AI_GEMINI_KEY=your_gemini_api_key_here

# Groq API Key (Optional, used as fallback)
GROQ_API_KEY=your_groq_api_key_here

# Google Maps API Key (Required for map features)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# QWeather (Hefeng) API Key (Required for weather server)
WEATHER_API_KEY=your_weather_api_key_here
